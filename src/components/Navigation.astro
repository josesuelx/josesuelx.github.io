---
const currentPath = Astro.url.pathname;
---

<div id='main-menu' class="navigation">
    <button id="menu-toggle" aria-label="Abrir menú">
        ☰
    </button>
    <ul id="menu-links">
        <a href="/" class={currentPath === "/" ? "active" : ""}>Inicio</a>
        <a href="/about" class={currentPath === "/about" || currentPath === "/about/" ? "active" : ""}>Sobre mi</a>
        <a href="/projects" class={currentPath === "/projects" || currentPath === "/projects/" ? "active" : ""}>Proyectos</a>
        <a href="/contact" class={currentPath === "/contact" || currentPath === "/contact/" ? "active" : ""}>Contacto</a>
    </ul>
</div>

<style>
    div {
        width: 100%;
        background-color: #33333388;
        padding: 1rem 0;
    }

    div ul {
        list-style: none;
        display: flex;
        justify-content: right;
        gap: 2rem;
        margin: 0;
        padding: 0;
        padding-right: 2rem;
    }

    #menu-toggle {
        display: none;
        background: none;
        border: none;
        color: #f0f0f0;
        font-size: 1.8rem;
        cursor: pointer;
        padding-right: 2rem;
    }

    div a {
        color: #f0f0f0;
        text-decoration: none;
        font-weight: bold;
    }

    div a:hover {
        text-decoration: underline;
    }

    div a.active {
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 4px;
    }

    @media (max-width: 768px) {
        #menu-toggle {
            display: block; 
            width: 100%;
            text-align: right;
        }

        div ul {
            display: none; /
            flex-direction: column;
            align-items: center;
            padding-right: 0;
            gap: 1rem;
            padding-top: 1rem;
        }

        div ul.expanded {
            display: flex;
        }
    }

</style>

<script>
    const menuToggle = document.getElementById('menu-toggle');
    const menuLinks = document.getElementById('menu-links');

    if (menuToggle && menuLinks) {
        menuToggle.addEventListener('click', () => {
            menuLinks.classList.toggle('expanded');
        });
    }
</script>
