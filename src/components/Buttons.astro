<style>
    .actions-container {
        display: flex;
        align-items: center;
        gap: 25px; 
        margin-top: 25px;
        flex-wrap: wrap; /* Asegura que en pantallas pequeñas se apilen si no caben */
    }

    .buttons {
        display: flex;
        gap: 15px;
    }

    .social-icons {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-link {
        color: #ccc; /* Gris claro que combina con tu texto de descripción */
        transition: color 0.3s ease, transform 0.3s ease;
        display: flex;
    }

    .icon-link:hover {
        color: #ff7b00; /* Naranja en hover */
        transform: translateY(-3px) scale(1.1); /* Efecto de saltar un poquito hacia arriba */
    }
</style>